{
  "manifest_version": 3,
  "name": "Hydra Download Manager",
  "version": "0.1.0",
  "description": "Send browser downloads to Hydra for fast, controllable downloading on your Mac.",
  "homepage_url": "https://github.com/pushipu/Hydra",
  "minimum_chrome_version": "123",
  "key": "",
  "permissions": [
    "downloads",
    "contextMenus",
    "cookies",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Hydra",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
